{
  "name": "@eu-ge-ne/toy",
  "version": "0.0.30",
  "license": "MIT",
  "exports": "",
  "workspace": [
    "src/libs/*",
    "src/plugins/*",
    "src/widgets/*"
  ],
  "compilerOptions": {
    "noUncheckedIndexedAccess": true
  },
  "fmt": {
    "lineWidth": 100
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ],
      "include": [
        "eqeqeq",
        "explicit-module-boundary-types",
        "explicit-function-return-type"
      ],
      "exclude": [
        "require-await"
      ]
    }
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/cli": "jsr:@std/cli@^1.0.29",
    "@std/fmt": "jsr:@std/fmt@^1.0.10"
  }
}
